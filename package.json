{
    "name": "@diia-inhouse/workflow",
    "version": "2.9.4",
    "description": "Workflow",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "repository": "https://github.com/diia-open-source/be-pkg-workflow",
    "author": "Diia",
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=24"
    },
    "bin": {
        "diia-workflow": "dist/cli/index.js"
    },
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./activity": {
            "types": "./dist/types/activity.d.ts",
            "import": "./dist/activity.js",
            "require": "./dist/activity.js"
        },
        "./client": {
            "types": "./dist/types/client.d.ts",
            "import": "./dist/client.js",
            "require": "./dist/client.js"
        },
        "./common": {
            "types": "./dist/types/common.d.ts",
            "import": "./dist/common.js",
            "require": "./dist/common.js"
        },
        "./operations": {
            "types": "./dist/types/operations.d.ts",
            "import": "./dist/operations.js",
            "require": "./dist/operations.js"
        },
        "./worker": {
            "types": "./dist/types/worker.d.ts",
            "import": "./dist/worker.js",
            "require": "./dist/worker.js"
        },
        "./testing": {
            "types": "./dist/types/testing.d.ts",
            "import": "./dist/testing.js",
            "require": "./dist/testing.js"
        }
    },
    "scripts": {
        "build": "rimraf dist && tsdown",
        "semantic-release": "semantic-release",
        "start": "npm run build && node dist/index.js",
        "lint": "oxlint && oxfmt --check .",
        "lint-fix": "oxlint --fix && oxfmt .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "prepare": "npm run build",
        "test": "tsc --project tests/tsconfig.json --noEmit && vitest run",
        "test:watch": "vitest watch",
        "find-circulars": "madge --circular --extensions ts ./"
    },
    "dependencies": {
        "@opentelemetry/api": "1.9.1",
        "@opentelemetry/exporter-trace-otlp-grpc": "0.57.2",
        "@opentelemetry/resources": "1.30.1",
        "@opentelemetry/sdk-trace-node": "1.30.1",
        "@opentelemetry/semantic-conventions": "1.40.0",
        "@temporalio/activity": "1.12.1",
        "@temporalio/client": "1.12.1",
        "@temporalio/common": "1.12.1",
        "@temporalio/interceptors-opentelemetry": "1.12.1",
        "@temporalio/proto": "1.12.1",
        "@temporalio/testing": "1.12.1",
        "@temporalio/worker": "1.12.1",
        "@temporalio/workflow": "1.12.1",
        "lodash": "4.18.1",
        "yargs": "18.0.0"
    },
    "peerDependencies": {
        "@diia-inhouse/diia-logger": ">=4.0.0",
        "@diia-inhouse/diia-metrics": ">=7.0.0",
        "@diia-inhouse/diia-queue": ">=14.0.0",
        "@diia-inhouse/env": ">=3.0.0",
        "@diia-inhouse/healthcheck": ">=2.0.0",
        "@diia-inhouse/types": ">=13.0.0",
        "@diia-inhouse/utils": ">=6.0.0"
    },
    "peerDependenciesMeta": {
        "@diia-inhouse/diia-queue": {
            "optional": true
        },
        "@diia-inhouse/healthcheck": {
            "optional": true
        }
    },
    "devDependencies": {
        "@diia-inhouse/configs": "7.0.1",
        "@diia-inhouse/diia-logger": "4.3.28",
        "@diia-inhouse/diia-metrics": "7.1.35",
        "@diia-inhouse/diia-queue": "14.0.27",
        "@diia-inhouse/env": "3.3.21",
        "@diia-inhouse/healthcheck": "2.1.40",
        "@diia-inhouse/oxc-config": "1.11.0",
        "@diia-inhouse/test": "8.2.14",
        "@diia-inhouse/types": "14.0.0",
        "@diia-inhouse/utils": "6.0.35",
        "@types/lodash": "4.17.24",
        "@types/node": "25.6.2",
        "@types/yargs": "17.0.35",
        "@vitest/coverage-v8": "4.1.5",
        "@vitest/ui": "4.1.5",
        "glob": "13.0.6",
        "lockfile-lint": "5.0.0",
        "madge": "8.0.0",
        "oxfmt": "0.48.0",
        "oxlint": "1.63.0",
        "oxlint-tsgolint": "0.22.1",
        "rimraf": "6.1.3",
        "semantic-release": "25.0.3",
        "tsdown": "0.22.0",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.1.5",
        "vitest-mock-extended": "4.0.0"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package",
        "branches": [
            "main"
        ]
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "type": "module",
    "license": null
}
